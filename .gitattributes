# Auto detect text files and perform LF normalization
* text=auto

# Force shell scripts to always use LF line endings
*.sh text eol=lf

# Force batch files to use CRLF (Windows)
*.bat text eol=crlf
*.cmd text eol=crlf

# Dockerfile and docker-compose should use LF
Dockerfile text eol=lf
docker-compose.yml text eol=lf
docker-compose.yaml text eol=lf

# Keep binary files as-is
*.db binary
*.sqlite binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
