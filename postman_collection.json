        {
          "name": "Create API Key",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-API-Key",
                "value": "{{api_key}}",
                "description": "Your existing admin API key"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My Integration\",\n  \"scopes\": [\"read:diary\", \"read:analytics\", \"read:recipes\"],\n  \"rate_limit\": 120,\n  \"expires_at\": \"2027-02-28T23:59:59Z\"\n}"
